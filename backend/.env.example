# Hosting mode switch (Requirement 15.6). Must be exactly "free" or "paid";
# any other value causes startup failure before serving traffic.
MODE=free

# Postgres connection strings selected at startup based on MODE.
# (Requirement 15.1: single managed Postgres instance per deployment.)
DATABASE_URL_FREE=postgres://postgres:kanna@localhost:5432/interview_assistant
DATABASE_URL_PAID=postgres://user:password@localhost:5432/interview_assistant

# Server-held master key for AES-256-GCM provider key encryption.
# Provide as base64-encoded 32 bytes.
MASTER_ENCRYPTION_KEY=a3Rnh7Wl4t8eyygNI+hk8jvllTdNAvkJ424IsmX7S+I=

# Razorpay credentials for the Orders API and webhook signature verification.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# HS256 secret used to sign access (60 min) and refresh (30 day) JWTs.
JWT_SECRET=YPOhpLxWaIiNvS1IEg2z1TlF2MyMP5jgmDGGXh71VdFMF82LJETEFpSznadm6x7-oCSBssqDWSeQdhf3Xb9zbQ

# Minimum accepted Desktop_Client build version (Requirement 13.2).
MIN_BUILD_VERSION=1.0.0

# Resend API key for email verification and password reset emails.
# Sign up at https://resend.com — free tier includes 100 emails/day.
# Must verify a sending domain in the Resend dashboard before sending.
RESEND_API_KEY=

# "From" address for transactional emails. Must be a verified domain or
# address in Resend. Format: "Display Name <email@domain.com>" or just
# "email@domain.com".
EMAIL_FROM=Interview Assistant <noreply@interview-assistant.dev>

# Base URL of the web app (used to build verification/reset links in emails).
# Defaults to http://localhost:5173 when not set.
WEB_APP_BASE_URL=http://localhost:5173
