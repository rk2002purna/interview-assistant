{
  "name": "upnod",
  "version": "1.0.0",
  "description": "UpNod - AI-powered interview co-pilot",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect",
    "build": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --x64 --mac",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.upnod.app",
    "productName": "UpNod",
    "icon": "build/icon",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false,
      "asarUnpack": [
        "node_modules/@lancedb/**",
        "node_modules/apache-arrow/**",
        "node_modules/pdfjs-dist/**",
        "node_modules/@xenova/**",
        "node_modules/onnxruntime-node/**",
        "node_modules/sharp/**"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false
    },
    "protocols": [
      {
        "name": "UpNod",
        "schemes": [
          "interview-assistant"
        ]
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "asarUnpack": [
        "node_modules/@lancedb/**",
        "node_modules/apache-arrow/**",
        "node_modules/pdfjs-dist/**",
        "node_modules/@xenova/**",
        "node_modules/onnxruntime-node/**",
        "node_modules/sharp/**"
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.13.0",
    "@xenova/transformers": "^2.17.2",
    "pdfjs-dist": "^4.9.155",
    "resend": "^6.12.3",
    "tesseract.js": "^5.1.1"
  }
}
